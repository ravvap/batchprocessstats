        {
          "name": "400 — POST missing required fields",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{batchRunnerToken}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startDateTime\": \"2024-06-01T02:00:00Z\",\n  \"type\": \"BATCH\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/batch-processing-statistics",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","batch-processing-statistics"]
            },
            "description": "Missing processName, recordsGathered etc. Returns 400 with errors array listing each violation."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('errors array present', () => {",
                  "    pm.expect(pm.response.json().errors).to.be.an('array').with.length.above(0);",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "400 — POST server-managed field in body",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{batchRunnerToken}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"00000000-0000-0000-0000-000000000001\",\n  \"processName\": \"Bad Request Test\",\n  \"startDateTime\": \"2024-06-01T02:00:00Z\",\n  \"type\": \"API\",\n  \"recordsGathered\": 0,\n  \"recordsChanged\": 0,\n  \"errorRecords\": 0,\n  \"processedRecords\": 0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/batch-processing-statistics",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","batch-processing-statistics"]
            },
            "description": "id, createdBy, createdDateTime, updatedBy, updatedDateTime must NOT be in the request body. Returns 400 with errors array naming each offending field."
          },
          "event": [
